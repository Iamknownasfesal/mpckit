{
  "name": "mpckit-workspace",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*",
    "examples/ts-*"
  ],
  "scripts": {
    "prepare": "lefthook install || true",
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.1",
    "@types/bun": "^1.1.13",
    "lefthook": "^2.1.6",
    "tsup": "^8.5.1",
    "turbo": "^2.3.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "packageManager": "bun@1.3.10"
}
