{
  "name": "@mpckit/sdk",
  "version": "0.2.0",
  "description": "MpcKit TypeScript SDK — hosted MPC signing for Sui dWallets.",
  "license": "BSD-3-Clause",
  "author": "fesal <fesal@dwalletlabs.com>",
  "homepage": "https://mpckit.xyz",
  "repository": {
    "type": "git",
    "url": "https://github.com/Iamknownasfesal/mpckit.git",
    "directory": "packages/sdk-ts"
  },
  "bugs": "https://github.com/Iamknownasfesal/mpckit/issues",
  "keywords": ["mpc", "sui", "ika", "dwallet", "wallet", "signing", "crypto"],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./eden": {
      "types": "./dist/eden.d.ts",
      "import": "./dist/eden.js"
    },
    "./worker-impl": {
      "types": "./dist/crypto/worker-impl.d.ts",
      "import": "./dist/crypto/worker-impl.js"
    }
  },
  "files": ["dist"],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "NODE_OPTIONS=\"--max-old-space-size=8192\" tsup",
    "prepublishOnly": "bun run build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "@elysiajs/eden": "^1.4.9",
    "@mpckit/core": "workspace:*",
    "@ika.xyz/sdk": "^0.4.1",
    "@mysten/sui": "^2.16.0"
  },
  "devDependencies": {
    "tsup": "^8.5.0",
    "typescript": "^6.0.3"
  }
}
