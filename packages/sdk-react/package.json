{
  "name": "@mpckit/react",
  "version": "0.3.0",
  "description": "TanStack Query bindings for the MPCKit SDK.",
  "license": "BSD-3-Clause",
  "author": "fesal <fesal@dwalletlabs.com>",
  "homepage": "https://mpckit.xyz",
  "repository": {
    "type": "git",
    "url": "https://github.com/Iamknownasfesal/mpckit.git",
    "directory": "packages/sdk-react"
  },
  "bugs": "https://github.com/Iamknownasfesal/mpckit/issues",
  "keywords": [
    "mpc",
    "sui",
    "react",
    "tanstack-query",
    "ika",
    "mpckit"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "NODE_OPTIONS=\"--max-old-space-size=8192\" tsup",
    "prepublishOnly": "bun run build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "@mpckit/sdk": "workspace:*"
  },
  "peerDependencies": {
    "@tanstack/react-query": "^5.0.0",
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^20.9.0",
    "@tanstack/react-query": "^5.0.0",
    "@testing-library/react": "^16.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "react": "^18.3.0",
    "react-dom": "^19.2.6",
    "tsup": "^8.5.0",
    "typescript": "^6.0.3"
  }
}
