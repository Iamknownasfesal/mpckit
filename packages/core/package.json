{
  "name": "@mpckit/core",
  "version": "0.2.0",
  "description": "Shared types and BCS schemas used by the MpcKit SDK.",
  "license": "BSD-3-Clause",
  "author": "fesal <fesal@dwalletlabs.com>",
  "homepage": "https://mpckit.xyz",
  "repository": {
    "type": "git",
    "url": "https://github.com/Iamknownasfesal/mpckit.git",
    "directory": "packages/core"
  },
  "bugs": "https://github.com/Iamknownasfesal/mpckit/issues",
  "keywords": ["mpc", "sui", "ika", "mpckit"],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "bun run build",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@mysten/sui": "^2.16.0"
  },
  "devDependencies": {
    "tsup": "^8.5.0",
    "typescript": "^6.0.3"
  }
}
