{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignore": [
      "dist",
      "build",
      "node_modules",
      ".turbo",
      ".next",
      "out",
      "coverage",
      "drizzle/meta",
      "target",
      "Cargo.lock"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 80,
    "lineEnding": "lf"
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "style": {
        "noNonNullAssertion": "off",
        "useImportType": "error",
        "useNodejsImportProtocol": "error",
        "useTemplate": "error",
        "useConst": "error"
      },
      "suspicious": {
        "noExplicitAny": "error",
        "noConsoleLog": "off"
      },
      "correctness": {
        "noUnusedImports": "error",
        "noUnusedVariables": "error",
        "useExhaustiveDependencies": "warn"
      },
      "complexity": {
        "noUselessTypeConstraint": "error",
        "useLiteralKeys": "error"
      },
      "performance": {
        "noDelete": "error"
      }
    }
  },
  "organizeImports": { "enabled": true },
  "javascript": {
    "formatter": { "quoteStyle": "double", "trailingCommas": "all" }
  },
  "overrides": [
    {
      "include": ["**/*.test.ts", "**/test/**/*.ts", "**/tests/**/*.ts"],
      "linter": {
        "rules": {
          "suspicious": { "noExplicitAny": "off" },
          "style": { "useImportType": "off" },
          "complexity": { "noStaticOnlyClass": "off" }
        }
      }
    },
    {
      "include": ["examples/**"],
      "linter": {
        "rules": {
          "correctness": { "noUnusedVariables": "warn" }
        }
      }
    },
    {
      "include": [
        "**/app/icon.tsx",
        "**/app/apple-icon.tsx",
        "**/app/opengraph-image.tsx",
        "**/app/twitter-image.tsx"
      ],
      "linter": {
        "rules": {
          "a11y": { "noSvgWithoutTitle": "off" }
        }
      }
    }
  ]
}
