# --- runtime ---
PORT=3000
LOG_LEVEL=info
NODE_ENV=development
# api | worker | both. `both` runs HTTP + workers in one process; for
# horizontal scaling deploy `api` and `worker` as separate fleets.
PROCESS_TYPE=both

# --- ika network (gRPC only; JSON-RPC and WS are deprecated upstream) ---
# One backend serves any subset of {testnet, mainnet}. A network is
# enabled when its MPCKITCORE_<NET>_PACKAGE_ID is set; the per-network
# gas-station block below must also be present. Backend logs which
# networks it brought up on boot and 4xxs requests targeting any
# disabled network.
IKA_DEFAULT_NETWORK=testnet                      # testnet | mainnet (default for anon endpoints)
# SUI_GRPC_URL_TESTNET=https://fullnode.testnet.sui.io:443
# SUI_GRPC_URL_MAINNET=https://fullnode.mainnet.sui.io:443

# --- mpckitcore Move package (filled by `bun run scripts/deploy.ts`) ---
MPCKITCORE_TESTNET_PACKAGE_ID=
MPCKITCORE_TESTNET_ADMIN_CAP_ID=
MPCKITCORE_TESTNET_OPERATOR_CAP_ID=
MPCKITCORE_TESTNET_TREASURY_ID=
# Mainnet block — leave blank to disable.
MPCKITCORE_MAINNET_PACKAGE_ID=
MPCKITCORE_MAINNET_ADMIN_CAP_ID=
MPCKITCORE_MAINNET_OPERATOR_CAP_ID=
MPCKITCORE_MAINNET_TREASURY_ID=
ALLOW_SHARED_DWALLETS=false

# --- hot wallet ---
# Provider selection: `env` reads HOT_WALLET_SUI_SECRET_HEX directly
# (dev / single-node only); `aws-kms` decrypts the wrapped ciphertext
# via AWS KMS at boot, so the plaintext seed never lives in env or
# container image. Production must use aws-kms; the operator's IAM
# role needs `kms:Decrypt` on the wrapping key.
HOT_WALLET_PROVIDER=env
# 32-byte ed25519 secret as hex; required when HOT_WALLET_PROVIDER=env.
HOT_WALLET_SUI_SECRET_HEX=
# Base64 KMS ciphertext blob; required when HOT_WALLET_PROVIDER=aws-kms.
# Generate once with:
#   openssl rand 32 > seed.bin
#   aws kms encrypt --key-id alias/mpckit-hot-wallet --plaintext fileb://seed.bin \
#       --output text --query CiphertextBlob > seed.b64
#HOT_WALLET_SUI_SECRET_KMS_CIPHERTEXT_B64=
# Optional: pin the KMS key id/ARN so a stolen role can't decrypt the
# ciphertext under a different key the attacker controls.
#HOT_WALLET_KMS_KEY_ID=alias/mpckit-hot-wallet
# Optional AWS region override (defaults to AWS_REGION).
#HOT_WALLET_KMS_REGION=us-east-1

# --- gas station (sui-gas-pool), per network ---
# Required per enabled network. The daemon binds to one fullnode per
# process, so each chain gets its own URL + auth token. compose ships
# one daemon (testnet by default); k8s base ships two — see
# infra/k8s/base/gas-station.yaml.
SUI_GAS_STATION_TESTNET_URL=http://gas-station:9527
SUI_GAS_STATION_TESTNET_AUTH=<bearer token shared with the testnet gas-station>
# Mainnet — leave blank to disable.
SUI_GAS_STATION_MAINNET_URL=
SUI_GAS_STATION_MAINNET_AUTH=
SUI_GAS_STATION_BUDGET_MIST=300000000     # 0.3 SUI per PTB; pool refunds unused portion
SUI_GAS_STATION_RESERVE_SECS=30           # reservation TTL; build+sign+submit must finish in this window
# Sponsor keypair for the pool itself (base64 SuiKeyPair: flag || privkey).
# One key sponsors both chains because the same address exists on both;
# fund it separately on each network.
SUI_GAS_STATION_SPONSOR_KEYPAIR_B64=

# --- L2 cache + L3 db ---
REDIS_URL=redis://localhost:6379
DATABASE_URL=postgres://ika:ika@localhost:5432/ika_api

# --- presign pool ---
PRESIGN_POOL_LOW_WATER=20
PRESIGN_POOL_HIGH_WATER=100
PRESIGN_RESERVATION_TTL_SEC=300
PRESIGN_BATCH_SIZE=10

# --- pricing safety multiplier (1.0 = pass through, 2.0 = 2x quote) ---
PRICING_SAFETY_MULTIPLIER=1.5

# --- off-chain credits billing ---
# 32-byte hex master seed; HKDF-derived per-user deposit keypair.
# Long-lived secret — rotating it orphans every existing deposit address.
BILLING_DEPOSIT_MASTER_SEED_HEX=
# Sui address where the sweeper consolidates funds.
BILLING_SWEEP_DESTINATION_ADDRESS=
# Minimum total USD value at a deposit address before sweeping (microUSD).
# Default $0.10. Below this the sweep reschedules to amortise gas.
BILLING_SWEEP_MIN_MICRO=100000

# Accepted deposit coin types (comma-separated).
BILLING_ACCEPTED_COIN_TYPES=0x2::sui::SUI

# All accounting is in microUSD (1 microUSD = $0.000001). Live USD
# prices for SUI + IKA come from CoinGecko (refreshed hourly); the
# values below are the seed/fallback used at boot and when the feed
# is down. Format: "coin_type=usd_price,coin_type=usd_price".
BILLING_USD_PRICES=0x2::sui::SUI=1.0
# Optional decimals overrides; SUI defaults to 9.
#BILLING_COIN_DECIMALS=
# CoinGecko ids per coin type. Coins absent here keep the static USD
# price above. SUI and IKA are mapped automatically at boot.
#BILLING_COINGECKO_IDS=0x2::sui::SUI=sui
# Refresh cadence in seconds (min 60, default 3600 = hourly).
#BILLING_PRICE_FEED_REFRESH_SEC=3600
# Maximum age (seconds) of the last successful CoinGecko poll before
# paid endpoints fail closed with PRICE_FEED_STALE. Default 4h.
#BILLING_PRICE_FEED_MAX_AGE_SEC=14400

# Op prices in microUSD. Defaults: sign=$0.01, dkg=$0.05, key=$0.001.
BILLING_PRICE_DKG_MICRO=50000
BILLING_PRICE_SIGN_MICRO=10000
BILLING_PRICE_ENCRYPTION_KEY_MICRO=1000

# Anti-dust: deposits below this microUSD threshold are rejected.
# Default $1.
BILLING_MIN_DEPOSIT_MICRO=1000000

# --- auth ---
ADMIN_API_KEY=                                  # bootstraps the first user

# --- observability (off by default) ---
# OTEL_EXPORTER_OTLP_ENDPOINT=https://otel.example.com:4318
# TELEMETRY_OPT_IN=false                          # send anon metrics to upstream
