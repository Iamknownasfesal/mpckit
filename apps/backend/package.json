{
  "name": "@mpckit/backend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "start": "bun run src/index.ts",
    "build": "bun build src/index.ts --target=bun --outdir=dist",
    "test": "bun test",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun run src/shared/db/migrate.ts"
  },
  "dependencies": {
    "@aws-sdk/client-kms": "^3.1045.0",
    "@better-auth/passkey": "^1.6.10",
    "@elysiajs/cors": "^1.4.2",
    "@elysiajs/eden": "^1.4.9",
    "@elysiajs/swagger": "^1.3.1",
    "@ika.xyz/sdk": "^0.4.1",
    "@mpckit/core": "workspace:*",
    "@mpckit/sdk": "workspace:*",
    "@mysten/sui": "^2.16.0",
    "@noble/curves": "^1.6.0",
    "@noble/hashes": "^1.5.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.76.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.218.0",
    "@opentelemetry/resources": "^2.7.1",
    "@opentelemetry/sdk-node": "^0.218.0",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "@sentry/bun": "^10.53.1",
    "better-auth": "^1.6.10",
    "dataloader": "^2.2.3",
    "drizzle-orm": "^0.45.2",
    "elysia": "^1.1.25",
    "ioredis": "^5.4.0",
    "lru-cache": "^11.0.2",
    "opossum": "^9.0.0",
    "p-retry": "^8.0.0",
    "pg-boss": "^12.18.2",
    "pino": "^10.3.1",
    "pino-pretty": "^11.3.0",
    "postgres": "^3.4.5",
    "prom-client": "^15.1.3",
    "rate-limiter-flexible": "^11.1.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/bun": "^1.1.13",
    "@types/opossum": "^8.1.8",
    "drizzle-kit": "^0.31.10",
    "typescript": "^6.0.3"
  }
}
