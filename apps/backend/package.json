{
  "name": "@mpckit/backend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "start": "bun run src/index.ts",
    "build": "bun build src/index.ts --target=bun --outdir=dist",
    "test": "bun test",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun run src/shared/db/migrate.ts"
  },
  "dependencies": {
    "@aws-sdk/client-kms": "^3.1045.0",
    "@better-auth/passkey": "^1.6.10",
    "@elysiajs/cors": "^1.4.2",
    "@elysiajs/eden": "^1.4.9",
    "@elysiajs/swagger": "^1.3.1",
    "@ika.xyz/sdk": "^0.4.1",
    "@mpckit/core": "workspace:*",
    "@mpckit/sdk": "workspace:*",
    "@mysten/sui": "^2.16.0",
    "@noble/curves": "^1.6.0",
    "@noble/hashes": "^1.5.0",
    "better-auth": "^1.6.10",
    "dataloader": "^2.2.3",
    "drizzle-orm": "^0.36.0",
    "elysia": "^1.1.25",
    "ioredis": "^5.4.0",
    "lru-cache": "^11.0.2",
    "opossum": "^8.4.0",
    "p-retry": "^6.2.1",
    "pg-boss": "^12.18.2",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "postgres": "^3.4.5",
    "prom-client": "^15.1.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "^1.1.13",
    "@types/opossum": "^8.1.8",
    "drizzle-kit": "^0.28.0",
    "typescript": "^5.6.3"
  }
}
